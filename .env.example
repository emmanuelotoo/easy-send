# Your WhatsApp account JID (the bot only responds to this account)
# Format: <countrycode><number>@s.whatsapp.net, e.g. 233241234567@s.whatsapp.net
OWNER_WHATSAPP_JID=233241234567@s.whatsapp.net

# Directory where Baileys stores the WhatsApp session (gitignored)
WHATSAPP_AUTH_DIR=data/wa-auth

# Your MTN MoMo phone number (for auto-funding via mobile money charge)
OWNER_PHONE=024XXXXXXX

# Email address (required by Paystack Charge API)
OWNER_EMAIL=you@example.com

# Paystack secret key (use sk_test_xxx for testing)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Spending limits (in GHS)
DAILY_LIMIT_GHS=500
PER_TRANSACTION_LIMIT_GHS=200
LOW_BALANCE_ALERT_GHS=50

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
