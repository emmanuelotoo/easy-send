# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your Telegram user ID (numeric, get from @userinfobot)
OWNER_TELEGRAM_ID=123456789

# Your Telecel phone number (for auto-funding via mobile money charge)
OWNER_PHONE=020XXXXXXX

# Email address (required by Paystack Charge API)
OWNER_EMAIL=you@example.com

# Paystack secret key (use sk_test_xxx for testing)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Spending limits (in GHS)
DAILY_LIMIT_GHS=500
PER_TRANSACTION_LIMIT_GHS=200
LOW_BALANCE_ALERT_GHS=50

# Default time for scheduled payments (24h format)
DEFAULT_SCHEDULE_TIME=09:00

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
